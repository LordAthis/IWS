Windows Registry Editor Version 5.00

; Brave böngésző: Rewards, Wallet és egyéb crypto funkciók letiltása
; Csökkenti a támadási felületet és a felesleges funkciókat

[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\BraveSoftware\Brave]
"BraveRewardsDisabled"=dword:00000001
"BraveWalletDisabled"=dword:00000001
"TorDisabled"=dword:00000000   ; Tor maradjon, ha kell (vagy 1-re állítsd ha nem akarod)
