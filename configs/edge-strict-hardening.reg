Windows Registry Editor Version 5.00

; Microsoft Edge szigorú megerősítés (Tracking Prevention Strict + SmartScreen)
; Forrás: Microsoft Edge Policies dokumentáció (2026)

[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Edge]
"TrackingPrevention"=dword:00000003
"SmartScreenEnabled"=dword:00000001
"WebRtcLocalhostIpHandling"=dword:00000001
"ConfigureDoNotTrack"=dword:00000001
"BlockThirdPartyCookies"=dword:00000001
